{
    "cli": {
        "version": ">= 13.0.0"
    },
    "build": {
        "development": {
            "distribution": "internal",
            "android": {
                "gradleCommand": ":app:assembleDebug"
            },
            "ios": {
                "buildType": "development"
            }
        },
        "preview": {
            "distribution": "internal",
            "env": {
                "NODE_ENV": "staging"
            },
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "buildType": "simulator"
            }
        },
        "production": {
            "distribution": "store",
            "env": {
                "NODE_ENV": "production"
            },
            "android": {
                "buildType": "app-bundle"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "YOUR_APP_ID_FROM_APP_STORE_CONNECT"
            },
            "android": {
                "serviceAccountKeyPath": "./service-account.json"
            }
        }
    }
}