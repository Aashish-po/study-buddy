# ============================================================================
# StudyBuddy AI - Environment Configuration Template
# Copy this file to .env and fill in with actual values
# DO NOT COMMIT .env - it contains sensitive secrets
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
# MySQL connection string
# Format: mysql://username:password@host:port/database
# Example: mysql://studybuddy:secure_password@db.example.com:3306/studybuddy_prod
DATABASE_URL=mysql://username:password@localhost:3306/studybuddy

# ============================================================================
# OAuth Configuration
# ============================================================================
# OAuth provider URL for authentication flow
OAUTH_SERVER_URL=https://your-oauth-provider.com

# Application ID from your OAuth provider
VITE_APP_ID=your_app_id_from_oauth_provider

# Your user ID from OAuth provider (for admin/owner access)
OWNER_OPEN_ID=your_owner_open_id_from_oauth_provider

# ============================================================================
# LLM Integration (NVIDIA Llama 3.3 70B via OpenAI API)
# ============================================================================
# NVIDIA API key for AI tutoring via Llama 3.3 70B model
# Get from: https://build.nvidia.com/meta/llama-3-3-70b-instruct
NVIDIA_API_KEY=your_nvidia_api_key_here

# ============================================================================
# ML Service Configuration
# ============================================================================
# ML microservice endpoint for advanced ML features
# Recommendation, knowledge gaps, retention prediction, study planning
# Default for development: http://localhost:8000
# Production: Use deployed ML service URL
ML_SERVICE_URL=http://localhost:8000

# ============================================================================
# JWT & Session Configuration
# ============================================================================
# Secret key for signing JWT tokens and cookies
# Generate with: openssl rand -hex 32
# SECURITY: Use a strong, random 32+ character secret in production
JWT_SECRET=your_32_char_random_secret_here

# ============================================================================
# Server Configuration
# ============================================================================
# Node.js environment
# Options: development, staging, production
NODE_ENV=production

# Server port
PORT=3000

# Metro bundler port for Expo (web/mobile dev)
EXPO_PORT=8081

# ============================================================================
# Error Tracking (Sentry)
# ============================================================================
# Get from https://sentry.io after creating a project
# Leave empty to disable Sentry tracking
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# Environment for Sentry error reporting
# Options: development, staging, production
SENTRY_ENVIRONMENT=production

# Release version for Sentry (update with each build)
SENTRY_RELEASE=1.0.0

# ============================================================================
# Analytics Configuration (Optional)
# ============================================================================
# Firebase project configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ============================================================================
# Feature Flags
# ============================================================================
# Enable/disable features without app updates
ENABLE_OFFLINE_MODE=false
ENABLE_CHAT_HISTORY=true
ENABLE_VOICE_INPUT=false
ENABLE_ANALYTICS=true

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Maximum API requests per window (15 minutes)
RATE_LIMIT_REQUESTS=100

# Rate limit window duration in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ============================================================================
# Development Settings (Only for development, never commit)
# ============================================================================
# Enable verbose logging in development
DEBUG=studybuddy:*

# Use ngrok for tunneling in development (for OAuth callback testing)
USE_NGROK=false
NGROK_AUTH_TOKEN=your_ngrok_token
